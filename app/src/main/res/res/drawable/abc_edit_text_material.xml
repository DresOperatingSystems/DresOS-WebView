<?xml version="1.0" encoding="utf-8"?>
<inset insetLeft="@dimen/abc_edit_text_inset_horizontal_material" insetRight="@dimen/abc_edit_text_inset_horizontal_material" insetTop="@dimen/abc_edit_text_inset_top_material" insetBottom="@dimen/abc_edit_text_inset_bottom_material">
    <selector>
        <item state_enabled="false">
            <nine-patch src="@drawable/abc_textfield_default_mtrl_alpha" tint="?attr/colorControlNormal" alpha="?android:attr/disabledAlpha"/>
        </item>
        <item state_focused="false" state_pressed="false">
            <nine-patch src="@drawable/abc_textfield_default_mtrl_alpha" tint="?attr/colorControlNormal"/>
        </item>
        <item>
            <nine-patch src="@drawable/abc_textfield_activated_mtrl_alpha" tint="?attr/colorControlActivated"/>
        </item>
    </selector>
</inset>
