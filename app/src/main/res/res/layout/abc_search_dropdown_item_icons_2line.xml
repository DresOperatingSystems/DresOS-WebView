    <ImageView id="@android:id/icon2" visibility="gone" layout_width="48dp" layout_height="48dp" scaleType="centerInside" layout_alignParentTop="true" layout_alignParentBottom="true" layout_alignWithParentIfMissing="true" style="@style/RtlOverlay.Widget.AppCompat.Search.DropDown.Icon2"/>
