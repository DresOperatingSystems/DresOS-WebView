<?xml version="1.0" encoding="utf-8"?>
<LinearLayout orientation="vertical" id="@+id/net_log_entry" clickable="true" layout_width="match_parent" layout_height="wrap_content">
    <TextView textAppearance="@style/MediumText" textStyle="bold" id="@+id/file_name" paddingTop="8dp" paddingBottom="8dp" clickable="false" layout_width="match_parent" layout_height="wrap_content" drawablePadding="4dp" paddingStart="8dp"/>
    <LinearLayout orientation="horizontal" layout_width="match_parent" layout_height="wrap_content">
        <TextView textAppearance="?android:attr/textAppearanceSmall" id="@+id/file_time" paddingBottom="8dp" clickable="false" layout_width="0dp" layout_height="wrap_content" layout_weight="1" paddingStart="8dp"/>
        <TextView textAppearance="?android:attr/textAppearanceSmall" id="@+id/file_capacity" paddingBottom="8dp" clickable="false" layout_width="wrap_content" layout_height="wrap_content" paddingEnd="8dp"/>
    </LinearLayout>
</LinearLayout>
