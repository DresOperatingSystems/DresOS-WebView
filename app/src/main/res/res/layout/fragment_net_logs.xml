<?xml version="1.0" encoding="utf-8"?>
<LinearLayout orientation="vertical" id="@+id/fragment_net_logs" layout_width="match_parent" layout_height="match_parent">
    <RelativeLayout orientation="horizontal" layout_width="match_parent" layout_height="wrap_content" layout_marginTop="8dp" layout_marginBottom="8dp">
        <Button textAppearance="?android:attr/textAppearanceMedium" id="@+id/delete_all_net_logs_button" layout_width="wrap_content" layout_height="wrap_content" text="Delete All" layout_centerVertical="true" layout_marginStart="8dp"/>
        <TextView textAppearance="?android:attr/textAppearanceSmall" id="@+id/net_logs_total_capacity" layout_width="wrap_content" layout_height="wrap_content" layout_centerVertical="true" layout_marginStart="8dp" layout_marginEnd="8dp" layout_toEndOf="@+id/delete_all_net_logs_button"/>
    </RelativeLayout>
    <View background="?android:attr/listDivider" layout_width="match_parent" layout_height="1dp"/>
    <ListView id="@+id/net_log_list" layout_width="match_parent" layout_height="match_parent"/>
</LinearLayout>
